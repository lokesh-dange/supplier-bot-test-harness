{
  "name": "sourcy-supplier-test-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first Node harness + UI for supplier-bot scenario replay (simulated or optional live export).",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server/harness-server.mjs",
